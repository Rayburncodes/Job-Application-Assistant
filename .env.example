# PostgreSQL connection string (used by Prisma)
# https://www.prisma.io/docs/orm/overview/databases/postgresql#connection-url
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"
#
# Local DB with docker compose in this folder (run: docker compose up -d):
# DATABASE_URL="postgresql://jobassistant:jobassistant@localhost:5432/jobassistant?schema=public"

# Cloudflare Workers AI
# Create an API token with permission to use Workers AI, and get your Account ID from Cloudflare dashboard.
CF_ACCOUNT_ID="your-cloudflare-account-id"
CF_AI_TOKEN="your-cloudflare-api-token"
# Default model (Workers AI)
CF_AI_MODEL="@cf/meta/llama-3.1-8b-instruct"

# Session signing for username/password login (min 16 characters; required in production)
AUTH_SECRET="replace-with-a-long-random-string-at-least-16-chars"
